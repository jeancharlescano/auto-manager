generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model car {
  id             Int            @id @default(autoincrement())
  user_id        Int
  brand          String         @db.VarChar(100)
  model          String         @db.VarChar(100)
  year           Int
  engine         String?        @db.VarChar(255)
  fuel_type      String?        @db.VarChar(50)
  horsepower_din Int?
  fiscal_power   Int?
  mileage        Int?
  tire_size      String?        @db.VarChar(50)
  color          String?        @db.VarChar(50)
  design         String?        @db.VarChar(255)
  created_at     DateTime?      @default(now()) @db.Timestamp(6)
  users          users          @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  maintenances   maintenance[]
}

model invoice {
  id             Int          @id @default(autoincrement())
  maintenance_id Int
  invoice_number String?      @db.VarChar(255)
  issue_date     DateTime?    @db.Date
  total_amount   Decimal?     @db.Decimal(10, 2)
  file_url       String?
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  maintenances   maintenance @relation(fields: [maintenance_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model maintenance_part {
  id             Int          @id @default(autoincrement())
  maintenance_id Int
  part_id        Int
  quantity       Int          @default(1)
  unit_price     Decimal?     @db.Decimal(10, 2)
  created_at     DateTime?    @default(now()) @db.Timestamp(6)
  maintenances   maintenance @relation(fields: [maintenance_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  parts          part        @relation(fields: [part_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model maintenance {
  id                Int                 @id @default(autoincrement())
  car_id            Int
  title             String              @db.VarChar(255)
  maintenance_date  DateTime            @db.Date
  mileage_at_time   Int
  total_cost        Decimal?            @db.Decimal(10, 2)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  invoices          invoice[]
  maintenance_parts maintenance_part[]
  cars              car                @relation(fields: [car_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model part {
  id                Int                 @id @default(autoincrement())
  name              String              @db.VarChar(255)
  reference         String?             @db.VarChar(255)
  created_at        DateTime?           @default(now()) @db.Timestamp(6)
  maintenance_parts maintenance_part[]
}

model users {
  id             Int       @id @default(autoincrement())
  name           String?   @db.VarChar(100)
  email          String    @unique @db.VarChar(255)
  email_verified DateTime? @db.Timestamp(6)
  password       String    @db.VarChar(255)
  image          String?
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  cars           car[]
}
